---
import '../styles/global.css';

export interface Props {
  title?: string;
}
const { title = "Pablo Martin — Directeur de la Photographie" } = Astro.props;
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>

    <slot />

    <footer>
      <span>© PABLO MARTIN</span>
      <span>DIRECTEUR DE LA PHOTOGRAPHIE</span>
    </footer>

    <style>
      footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 32px 56px;
        border-top: 1px solid var(--border);
        font-size: 0.75rem;
        color: var(--text-muted);
        letter-spacing: 0.08em;
      }
    </style>

  </body>
</html>