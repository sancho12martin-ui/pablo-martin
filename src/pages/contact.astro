---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Pablo Martin">

  <nav class="onglets" id="nav-onglets">
    <a href="/" class="onglet">Narratif</a>
    <a href="/video" class="onglet">Vidéo</a>
    <a href="/etalonnage" class="onglet">Étalonnage</a>
    <a href="/timeline" class="onglet">Timeline</a>
    <a href="/contact" class="onglet actif">Contact</a>
  </nav>

  <section class="contact-header">
    <h1 class="contact-titre">Contact</h1>
    <p class="contact-sous-titre">Disponible pour nouveaux projets</p>
  </section>

  <section class="contact-body">

    <div class="contact-infos">
      <div class="info-bloc">
        <p class="info-label">Email</p>
        <a href="mailto:pablo12martin@gmail.com" class="info-valeur">pablo12martin@gmail.com</a>
      </div>
      <div class="info-bloc">
        <p class="info-label">Basé à</p>
        <p class="info-valeur">Toulouse, France</p>
      </div>
      <div class="info-bloc">
        <p class="info-label">Réseaux</p>
        <div class="reseaux">
          <a href="https://www.instagram.com/instouzou/" target="_blank" rel="noopener" class="reseau-lien">Instagram</a>
          <a href="https://vimeo.com/user128877784" target="_blank" rel="noopener" class="reseau-lien">Vimeo</a>
          <a href="https://www.youtube.com/@Pablo12Martin" target="_blank" rel="noopener" class="reseau-lien">YouTube</a>
          <a href="https://www.linkedin.com/in/pablo-martin-910780212/" target="_blank" rel="noopener" class="reseau-lien">LinkedIn</a>
          <a href="https://www.lightyshare.com/fr/public/15940/show" target="_blank" rel="noopener" class="reseau-lien">Lightyshare</a>
        </div>
      </div>
    </div>

    <form class="contact-form" action="https://formspree.io/f/meenbqdq" method="POST">
      <div class="form-groupe">
        <label class="form-label" for="nom">Nom</label>
        <input class="form-input" type="text" id="nom" name="nom" placeholder="Votre nom" required />
      </div>
      <div class="form-groupe">
        <label class="form-label" for="email">Email</label>
        <input class="form-input" type="email" id="email" name="email" placeholder="votre@email.com" required />
      </div>
      <div class="form-groupe">
        <label class="form-label" for="sujet">Sujet</label>
        <input class="form-input" type="text" id="sujet" name="sujet" placeholder="Projet, collaboration..." />
      </div>
      <div class="form-groupe">
        <label class="form-label" for="message">Message</label>
        <textarea class="form-textarea" id="message" name="message" placeholder="Décrivez votre projet..." rows="6" required></textarea>
      </div>
      <button class="form-submit" type="submit">Envoyer →</button>
      <p class="form-success" id="form-success">Message envoyé — je vous répondrai dès que possible !</p>
    </form>

  </section>

</Layout>

<style>
  .onglets {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--bg);
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--border);
    padding: 0 56px;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .onglets::-webkit-scrollbar { display: none; }
  .onglet {
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-muted);
    padding: 20px 24px;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
    transition: color 0.2s, border-color 0.2s;
  }
  .onglet:hover { color: var(--text); }
  .onglet.actif { color: var(--accent); border-bottom-color: var(--accent); }

  .contact-header {
    padding: 64px 56px 48px;
    border-bottom: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .contact-titre {
    font-family: Helvetica, Arial, sans-serif;
    font-weight: 800;
    font-size: 64px;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .contact-sous-titre {
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .contact-body {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 10px;
    padding: 64px 56px;
  }

  /* ── INFOS ── */
  .contact-infos {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .info-bloc {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .info-label {
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--accent);
    opacity: 0.8;
  }

  .info-valeur {
    font-size: 15px;
    color: var(--text);
    text-decoration: none;
    transition: color 0.2s;
  }

  a.info-valeur:hover { color: var(--accent); }

  .reseaux {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .reseau-lien {
    font-size: 14px;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .reseau-lien:hover { color: var(--accent); }

  /* ── FORMULAIRE ── */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .form-groupe {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-label {
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .form-input,
  .form-textarea {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: Helvetica, Arial, sans-serif;
    font-size: 14px;
    padding: 14px 16px;
    outline: none;
    transition: border-color 0.2s;
    resize: none;
    width: 100%;
  }

  .form-input:focus,
  .form-textarea:focus {
    border-color: var(--accent);
  }

  .form-input::placeholder,
  .form-textarea::placeholder {
    color: var(--text-muted);
    opacity: 0.5;
  }

  .form-submit {
    font-family: Helvetica, Arial, sans-serif;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--bg);
    background: var(--accent);
    border: none;
    padding: 16px 32px;
    cursor: pointer;
    width: fit-content;
    font-weight: 700;
    transition: opacity 0.2s;
  }

  .form-submit:hover { opacity: 0.85; }

  .form-success {
    font-size: 13px;
    letter-spacing: 1px;
    color: var(--accent);
    display: none;
  }

  .form-success.visible { display: block; }
</style>

<script is:inline>
  const form = document.querySelector('.contact-form');
  const success = document.getElementById('form-success');

  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    const data = new FormData(form);
    const response = await fetch('https://formspree.io/f/meenbqdq', {
      method: 'POST',
      body: data,
      headers: { 'Accept': 'application/json' }
    });

    if (response.ok) {
      form.reset();
      success.classList.add('visible');
      setTimeout(() => success.classList.remove('visible'), 5000);
    }
  });
</script>