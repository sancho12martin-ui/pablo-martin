---
import Layout from '../../layouts/Layout.astro';
import films from '../../data/narratif.json';
import { getFilmImages } from '../../lib/cloudinary.js';

const filmsAvecImages = await Promise.all(
  films.map(async (film: any) => {
    const { cover, images_film } = await getFilmImages(film.slug);
    return {
      ...film,
      cover: cover || null,
      photos: images_film,
    };
  })
);
---

<Layout title="Narratif — Pablo Martin">

  <div class="page-header">
    <a href="/" class="retour">← Accueil</a>
    <h1 class="page-titre">Narratif</h1>
    <p class="page-sous-titre">Courts-métrages · Fiction · Documentaire</p>
  </div>

  <nav class="onglets">
    <a href="/narratif" class="onglet actif">Narratif</a>
    <a href="/clips" class="onglet">Clips</a>
    <a href="/video" class="onglet">Vidéo</a>
    <a href="/etalonnage" class="onglet">Étalonnage</a>
    <a href="/timeline" class="onglet">Timeline</a>
    <a href="/contact" class="onglet">Contact</a>
  </nav>

  <section class="films-liste">
    {filmsAvecImages.map((film: any) => (
      <article class="film-card">
        <a href={`/narratif/${film.slug}`} class="film-visuel">
          <div class="film-cover">
            {film.cover ? (
              <img src={film.cover} alt={film.titre} loading="lazy" />
            ) : (
              <div class="cover-placeholder"><span>Image bientôt disponible</span></div>
            )}
            <div class="film-cover-overlay">
              <span class="voir-projet">Voir le projet →</span>
            </div>
          </div>
          <div class="film-mosaique">
            {film.photos.slice(0, 6).map((photo: string, i: number) => (
              <div class="mosaique-item">
                <img src={photo} alt={`${film.titre} — photo ${i + 1}`} loading="lazy" />
              </div>
            ))}
          </div>
        </a>
        <div class="film-infos">
          <div class="film-meta">
            {film.genre && <span class="film-genre-label">{film.genre}</span>}
            {film.duree && <><span class="sep">·</span><span>{film.duree}</span></>}
            {film.pays && <><span class="sep">·</span><span>{film.pays}</span></>}
            {film.annee && <><span class="sep">·</span><span>{film.annee}</span></>}
          </div>
          <h2 class="film-titre">
            <a href={`/narratif/${film.slug}`}>{film.titre}</a>
          </h2>
          <div class="film-roles">
            {film.roles.map((role: string) => (
              <span class="role-tag">{role}</span>
            ))}
          </div>
          <p class="film-real"><span class="real-label">Réal.</span> {film.real}</p>
          {film.prix && <div class="film-prix-card">🏆 {film.prix}</div>}
        </div>
        <div class="film-separateur"></div>
      </article>
    ))}
  </section>

</Layout>

<style>
  .page-header {
    padding: 48px 56px 32px;
    border-bottom: 1px solid var(--border);
  }

  .retour {
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-muted);
    transition: color 0.2s;
    display: inline-block;
    margin-bottom: 24px;
  }
  .retour:hover { color: var(--accent); }

  .page-titre {
    font-family: Helvetica, Arial, sans-serif;
    font-weight: 800;
    font-size: 64px;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .page-sous-titre {
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-top: 10px;
  }

  .onglets {
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--border);
    padding: 0 56px;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .onglets::-webkit-scrollbar { display: none; }

  .onglet {
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-muted);
    padding: 20px 24px;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
    transition: color 0.2s, border-color 0.2s;
  }
  .onglet:hover { color: var(--text); }
  .onglet.actif {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .films-liste {
    padding: 64px 56px;
    display: flex;
    flex-direction: column;
  }

  .film-card { padding: 48px 0; }

  .film-separateur {
    height: 1px;
    background: var(--border);
    margin-top: 48px;
  }
  .film-card:last-child .film-separateur { display: none; }

  .film-visuel {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
    margin-bottom: 28px;
    cursor: pointer;
    align-items: stretch;
  }

  .film-cover {
    position: relative;
    min-height: 480px;
    overflow: hidden;
    background: var(--bg-surface);
  }

  .film-cover img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
    filter: none;
  }

  .cover-placeholder {
    width: 100%; height: 100%;
    min-height: 480px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  .film-cover-overlay {
    position: absolute;
    inset: 0;
    background: rgba(26, 31, 46, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .voir-projet {
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 10px 24px;
  }

  .film-visuel:hover .film-cover img { transform: scale(1.03); }
  .film-visuel:hover .film-cover-overlay { opacity: 1; }

  .film-mosaique {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(3, 1fr);
    gap: 4px;
    height: 100%;
  }

  .mosaique-item {
    overflow: hidden;
    background: var(--bg-surface);
    cursor: pointer;
    display: block;
    width: 100%;
    height: 100%;
  }

  .mosaique-item img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
    filter: none;
  }
  .film-visuel:hover .mosaique-item img { transform: scale(1.04); }

  .film-infos {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .film-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .sep {
    color: var(--text-muted);
    font-size: 20px;
    line-height: 1;
    opacity: 0.8;
  }

  .film-genre-label {
    color: var(--accent);
  }

  .film-titre {
    font-family: Helvetica, Arial, sans-serif;
    font-weight: 800;
    font-size: 38px;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--text);
  }
  .film-titre a:hover { color: var(--accent); }

  .film-roles {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .role-tag {
    font-size: 13px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-muted);
    border: 1px solid var(--border);
    padding: 4px 12px;
    font-weight: 800;
  }

  .film-real {
    font-size: 13px;
    letter-spacing: 1px;
    color: var(--text-muted);
  }

  .real-label {
    color: var(--accent);
  }

  .film-prix-card {
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--accent);
  }
</style>