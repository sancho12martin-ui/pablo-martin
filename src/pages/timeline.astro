---
import Layout from '../layouts/Layout.astro';
import presse from '../data/presse.json';
import parcours from '../data/parcours.json';
import prix from '../data/prix.json';

const tous = [...presse, ...parcours, ...prix].sort((a: any, b: any) => {
  return parseInt(b.annee) - parseInt(a.annee);
});

let derniereAnneeAffichee = "";
---

<Layout title="Timeline — Pablo Martin">

  <nav class="onglets" id="nav-onglets">
    <a href="/" class="onglet">Narratif</a>
    <a href="/video" class="onglet">Vidéo</a>
    <a href="/etalonnage" class="onglet">Étalonnage</a>
    <a href="/timeline" class="onglet actif">Timeline</a>
    <a href="/contact" class="onglet">Contact</a>
  </nav>

  <section class="timeline-header">
    <h1 class="timeline-titre">Timeline</h1>
    <p class="timeline-sous-titre">Parcours, récompenses et presse</p>
    
    <div class="filtres">
      <button class="filtre actif" data-filtre="tous">Tout</button>
      <button class="filtre" data-filtre="parcours">Parcours</button>
      <button class="filtre" data-filtre="presse">Presse</button>
      <button class="filtre" data-filtre="prix">Prix</button>
    </div>
  </section>

  <section class="timeline-liste">
    {tous.map((e: any) => {
      const estNouvelleAnnee = e.annee !== derniereAnneeAffichee;
      if (estNouvelleAnnee) derniereAnneeAffichee = e.annee;

      return (
        <article class={`timeline-card type-${e.type}`} data-type={e.type}>
          
          <div class="timeline-gauche">
            <div class="sticky-container">
              <span class={`timeline-annee ${!estNouvelleAnnee ? 'annee-masquee' : ''}`}>
                {e.annee}
              </span>
              <span class="timeline-mois">{e.mois}</span>
              <span class={`timeline-badge badge-${e.type}`}>
                {e.type === 'parcours' ? (e.categorie || 'parcours') : e.type === 'presse' ? 'article' : e.type}
              </span>
            </div>
          </div>

          <div class={`timeline-droite ${e.image ? 'avec-image' : 'sans-image'}`}>
            
            {e.image && (
              <div class="timeline-media">
                <button class="timeline-image-btn" aria-label="Agrandir l'image">
                  <img src={e.image} alt={e.titre} class="timeline-image" loading="lazy" />
                </button>
              </div>
            )}

            <div class="timeline-texte">
              <div class="timeline-meta">
                {e.source && <span class="timeline-category-label">{e.source}</span>}
                {e.festival && <span class="timeline-category-label">🏆 {e.festival}</span>}
              </div>
              
              <h2 class="timeline-card-titre">{e.titre}</h2>
              
              <div class="timeline-details">
                {e.film && <p class="info-line">🎬 {e.film}{e.real ? ` — Réal. ${e.real}` : ''}</p>}
                {e.lieu && <p class="info-line">📍 {e.lieu}</p>}
              </div>

              <p class="timeline-description">{e.description}</p>
              
              <div class="timeline-actions">
                {e.type === 'prix' && e.slug && (
                  <a href={`/narratif/${e.slug}`} class="cta-yellow">
                    Voir le projet <span>→</span>
                  </a>
                )}
                
                {(e.lien || e.url) && (
                  <a href={e.lien || e.url} target="_blank" rel="noopener" class="cta-yellow">
                    {e.type === 'presse' ? "Lire l'article" : "Voir le film"} <span>→</span>
                  </a>
                )}
              </div>
            </div>
          </div>
          <div class="timeline-separateur"></div>
        </article>
      );
    })}
  </section>

  <!-- LIGHTBOX AVEC CROIX SOBRE -->
  <div class="lightbox" id="lightbox" aria-hidden="true">
    <div class="lightbox-bg" id="lightbox-bg"></div>
    <button class="lightbox-close" id="lightbox-close" aria-label="Fermer">✕</button>
    <div class="lightbox-content">
      <img class="lightbox-img" id="lightbox-img" src="" alt="" />
    </div>
  </div>

</Layout>

<style>
  /* --- NAVIGATION --- */
  .onglets {
    position: sticky; top: 0; z-index: 100; background: var(--bg);
    display: flex; align-items: center; border-bottom: 1px solid var(--border);
    padding: 0 56px; overflow-x: auto; scrollbar-width: none;
  }
  .onglets::-webkit-scrollbar { display: none; }
  .onglet {
    font-size: 12px; letter-spacing: 2px; text-transform: uppercase;
    color: var(--text-muted); padding: 20px 24px; border-bottom: 2px solid transparent;
    white-space: nowrap; transition: 0.2s; text-decoration: none;
  }
  .onglet.actif { color: var(--accent); border-bottom-color: var(--accent); }

  /* --- HEADER --- */
  .timeline-header { padding: 64px 56px 48px; border-bottom: 1px solid var(--border); display: flex; flex-direction: column; gap: 8px; }
  .timeline-titre { font-family: Helvetica, Arial, sans-serif; font-weight: 800; font-size: 64px; line-height: 1; letter-spacing: -0.02em; color: var(--text); }
  .timeline-sous-titre { font-size: 12px; letter-spacing: 2px; text-transform: uppercase; color: var(--text-muted); margin-bottom: 24px; }

  /* --- FILTRES --- */
  .filtres { display: flex; gap: 10px; }
  .filtre { background: none; border: 1px solid var(--border); color: var(--text-muted); padding: 8px 16px; font-size: 10px; letter-spacing: 1px; text-transform: uppercase; cursor: pointer; transition: 0.2s; }
  .filtre.actif { border-color: var(--accent); color: var(--accent); }

  /* --- CARTES & TEXTES --- */
  .timeline-liste { padding: 0 56px 100px; }
  .timeline-card { display: grid; grid-template-columns: 140px 1fr; gap: 60px; padding: 80px 0; position: relative; }
  .timeline-card.masque { display: none; }
  .timeline-category-label { display: block; font-size: 14px; font-weight: 800; letter-spacing: 2px; text-transform: uppercase; color: var(--accent); margin-bottom: 12px; }
  .timeline-card-titre { font-size: clamp(28px, 4vw, 40px); font-weight: 800; color: var(--text); line-height: 1.1; margin-bottom: 24px; }
  .cta-yellow { color: var(--accent); text-decoration: none; font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; display: inline-flex; align-items: center; gap: 8px; transition: 0.2s; }
  .cta-yellow:hover { color: var(--text); padding-left: 5px; }

  /* --- IMAGES --- */
  .timeline-droite { display: grid; gap: 40px; align-items: start; }
  .avec-image { grid-template-columns: 320px 1fr; }
  .timeline-media { border-radius: 4px; overflow: hidden; background: var(--bg-surface); }
  .timeline-image-btn { border: none; padding: 0; background: none; cursor: pointer; width: 100%; display: block; }
  .timeline-image { width: 100%; height: auto; display: block; transition: 0.3s; }
  .timeline-image-btn:hover .timeline-image { opacity: 0.7; }

  /* --- DIVERS --- */
  .info-line { font-size: 14px; color: var(--text-muted); margin-bottom: 4px; }
  .timeline-description { font-size: 16px; line-height: 1.6; color: var(--text-muted); max-width: 700px; margin-top: 16px; }
  .timeline-annee { font-size: 48px; font-weight: 800; color: var(--text); }
  .annee-masquee { opacity: 0.1; }
  .sticky-container { position: sticky; top: 120px; }
  .timeline-separateur { position: absolute; bottom: 0; left: 0; width: 100%; height: 1px; background: var(--border); }

  /* --- LIGHTBOX SOBRE --- */
  .lightbox { position: fixed; inset: 0; z-index: 9999; display: none; align-items: center; justify-content: center; }
  .lightbox.open { display: flex; }
  .lightbox-bg { position: absolute; inset: 0; background: rgba(0,0,0,0.92); backdrop-filter: blur(8px); }
  .lightbox-content { position: relative; z-index: 10; max-width: 90vw; max-height: 85vh; }
  .lightbox-img { max-width: 100%; max-height: 85vh; object-fit: contain; }

  .lightbox-close {
    position: fixed;
    top: 30px;
    right: 30px;
    z-index: 100;
    background: none;
    border: none;
    color: white;
    font-size: 32px;
    font-weight: 200;
    cursor: pointer;
    padding: 10px;
    line-height: 1;
    transition: opacity 0.2s;
    opacity: 0.5;
  }
  .lightbox-close:hover { opacity: 1; }

  @media (max-width: 1024px) {
    .timeline-card { grid-template-columns: 1fr; gap: 32px; padding: 48px 0; }
    .avec-image { grid-template-columns: 1fr; }
    .timeline-header, .timeline-liste { padding-left: 24px; padding-right: 24px; }
    .onglets { padding: 0 24px; }
  }
</style>

<script is:inline>
  // FILTRES
  const buttons = document.querySelectorAll('.filtre');
  const items = document.querySelectorAll('.timeline-card');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => b.classList.remove('actif'));
      btn.classList.add('actif');
      const filter = btn.getAttribute('data-filtre');
      items.forEach(item => {
        item.classList.toggle('masque', filter !== 'tous' && item.getAttribute('data-type') !== filter);
      });
    });
  });

  // LIGHTBOX
  const lb = document.getElementById('lightbox');
  const lbImg = document.getElementById('lightbox-img');
  
  document.querySelectorAll('.timeline-image-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const img = btn.querySelector('img');
      if (img) {
        lbImg.src = img.src;
        lb.classList.add('open');
        document.body.style.overflow = 'hidden';
      }
    });
  });

  const closeLB = () => {
    lb.classList.remove('open');
    document.body.style.overflow = '';
  };

  document.getElementById('lightbox-bg').addEventListener('click', closeLB);
  document.getElementById('lightbox-close').addEventListener('click', closeLB);
  document.addEventListener('keydown', (e) => { if(e.key === 'Escape') closeLB(); });
</script>