---
import Layout from '../layouts/Layout.astro';
import films from '../data/narratif.json';
import { getFilmImages } from '../lib/cloudinary.js';

const filmsAvecImages = await Promise.all(
  films.map(async (film: any) => {
    const { cover, images_film } = await getFilmImages(film.slug);
    return {
      ...film,
      cover: cover || null,
      photos: images_film,
    };
  })
);

const reseaux = [
  // On ajoute la classe 'mail-img' ici
  { nom: "Email", url: "mailto:pablo12martin@gmail.com", actif: true, img: `/images/mail_logo.svg`, classe: 'mail-img' }, 
  { nom: "Instagram", url: "https://www.instagram.com/instouzou/", actif: true, img: `/images/instagram_logo.svg` },
  { nom: "Vimeo", url: "https://vimeo.com/user128877784", actif: true, img: `/images/vimeo_logo.svg` },
  { nom: "YouTube", url: "https://www.youtube.com/@Pablo12Martin", actif: true, img: `/images/youtube_logo.svg` },
  // On ajoute la classe 'lighty-img' ici
  { nom: "Lightyshare", url: "https://www.lightyshare.com/fr/public/15940/show", actif: true, img: `/images/Lightyshare_logo.png`, classe: 'lighty-img' }, 
  { nom: "LinkedIn", url: "https://www.linkedin.com/in/pablo-martin-910780212/", actif: true, img: `/images/linkedin_logo.svg` },
  { nom: "IMDb", url: null, actif: true, img: `/images/IMBd_logo.png`, classe: 'imdb-img' },
];

const vimeoId = "1191904895";
---

<Layout title="Pablo Martin — Directeur de la Photographie">

  <section class="hero">
    <div class="video-bg">
      <iframe
        src={`https://player.vimeo.com/video/${vimeoId}?autoplay=1&muted=1&loop=1&background=1`}
        frameborder="0"
        allow="autoplay; fullscreen"
        allowfullscreen
      ></iframe>
    </div>
    <div class="overlay-top"></div>
    <div class="overlay-bottom"></div>
    <div class="hero-content">
      <div class="hero-info">
        <div class="hero-textes">
          <h1 class="hero-nom">Pablo Martin</h1>
          <p class="hero-fonction">Directeur de la Photographie</p>
        </div>
        <div class="reseaux">
          {reseaux.map((r) => (
            r.actif ? (
              <a href={r.url} target="_blank" rel="noopener" class="reseau-btn actif" aria-label={r.nom}>
                <span class="reseau-icone">
                  <img src={r.img} alt={r.nom} class={`reseau-img ${'classe' in r ? r.classe : ''}`} />
                </span>
              </a>
            ) : (
              <span class="reseau-btn inactif" title={`${r.nom} — bientôt disponible`}>
                <span class="reseau-icone">
                  <img src={r.img} alt={r.nom} class={`reseau-img inactif-img ${'classe' in r ? r.classe : ''}`} />
                </span>
              </span>
            )
          ))}
        </div>
      </div>
      <a href="#nav-onglets" class="scroll-hint">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M10 4v12M4 10l6 6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </section>

  <nav class="onglets" id="nav-onglets">
    <a href="#narratif" class="onglet actif">Narratif</a>
    <a href="/video" class="onglet">Vidéo</a>
    <a href="/etalonnage" class="onglet">Étalonnage</a>
    <a href="/timeline" class="onglet">Timeline</a>
    <a href="/contact" class="onglet">Contact</a>
  </nav>

  <section class="films-liste" id="narratif">
    {filmsAvecImages.map((film: any) => (
      <article class="film-card">

        <div class="film-header">
          <h2 class="film-titre">
            <a href={`/narratif/${film.slug}`}>{film.titre}</a>
          </h2>
          <div class="film-meta">
            {film.genre && <span class="film-genre-label">{film.genre}</span>}
            {film.duree && <><span class="sep">·</span><span class="film-duree">{film.duree}</span></>}
            {film.pays && <><span class="sep">·</span><span>{film.pays}</span></>}
            {film.annee && <><span class="sep">·</span><span>{film.annee}</span></>}
          </div>
          <p class="film-real"><span class="real-label">Réal.</span> {film.real}</p>
          <div class="film-roles">
            {film.roles.map((role: string) => (
              <span class="role-tag">{role}</span>
            ))}
          </div>
          {film.prix && (
            <div class="film-prix-card">🏆 {film.prix}</div>
          )}
        </div>

        <div class="film-visuel">
          <a href={`/narratif/${film.slug}`} class="film-cover">
            {film.cover ? (
              <img src={film.cover} alt={film.titre} loading="lazy" />
            ) : (
              <div class="cover-placeholder">
                <span>Image bientôt disponible</span>
              </div>
            )}
            <div class="film-cover-overlay">
              <span class="voir-projet">Voir le projet →</span>
            </div>
          </a>

          <div class="film-mosaique" data-photos={JSON.stringify(film.photos)}>
            {film.photos.slice(0, 12).map((photo: string, i: number) => (
              <button
                class="mosaique-item"
                data-index={String(i)}
                aria-label={`Agrandir photo ${i + 1}`}
              >
                <img src={photo} alt={`${film.titre} — ${i + 1}`} loading="lazy" />
              </button>
            ))}
          </div>
        </div>

        <div class="film-infos-bas">
          {film.credits && (
            <p class="infos-ligne">
              {film.credits['Production'] && (
                <span class="infos-item">
                  <span class="infos-poste">Prod.</span>
                  <span class="infos-nom">{film.credits['Production']}</span>
                </span>
              )}
              {Object.entries(film.credits)
                .filter(([key, val]: [string, any]) =>
                  val !== null && (
                    key === '1er assistant caméra' ||
                    key === '2ème assistant caméra' ||
                    key === '3ème assistant caméra' ||
                    key === 'Assistant Caméra'
                  )
                )
                .map(([, nom]: [string, any], i: number) => (
                  <span class="infos-item">
                    {i === 0 && <span class="separateur-bloc">|</span>}
                    {i === 0 && <span class="infos-poste">Ass. Cam.</span>}
                    {i > 0 && <span class="sep">·</span>}
                    <span class="infos-nom">{nom}</span>
                  </span>
                ))
              }
              {film.credits['Prestataires techniques'] && (
                <span class="infos-item">
                  <span class="separateur-bloc">|</span>
                  <span class="infos-poste">Prestataire Technique</span>
                  {film.credits['Prestataires techniques'].split(' · ').map((p: string, i: number) => (
                    <span class="infos-item">
                      {i > 0 && <span class="sep">·</span>}
                      <span class="infos-nom">{p}</span>
                    </span>
                  ))}
                </span>
              )}
            </p>
          )}
          {film.cameras && (
            <div class="cameras-bloc">
              {film.cameras.map((cam: any) => (
                <div class="infos-row camera-row">
                  <span class="camera-emoji">{cam.type === 'numerique' ? '📹' : '🎥'}</span>
                  <span class="infos-nom">{cam.nom}</span>
                  {cam.format && <><span class="dot">/</span><span class="infos-nom">{cam.format}</span></>}
                  {cam.laboratoire && <><span class="dot">/</span><span class="infos-nom">Labo. {cam.laboratoire}</span></>}
                  {cam.type === 'numerique' && cam.optiques && <><span class="dot">/</span><span class="infos-nom">{cam.optiques}</span></>}
                </div>
              ))}
            </div>
          )}
        </div>

        <div class="film-separateur"></div>
      </article>
    ))}
  </section>

  <div class="lightbox" id="lightbox">
    <div class="lightbox-bg" id="lightbox-bg"></div>
    <button class="lightbox-close" id="lightbox-close">✕</button>
    <button class="lightbox-prev" id="lightbox-prev">‹</button>
    <button class="lightbox-next" id="lightbox-next">›</button>
    <img class="lightbox-img" id="lightbox-img" src="" alt="" />
    <p class="lightbox-counter" id="lightbox-counter"></p>
  </div>

</Layout>

<style>
.hero {
    position: relative;
    width: 100%;
    height: 80vh;
    min-height: 500px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }

  .video-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .video-bg iframe {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100vw;
    height: 56.25vw;
    min-height: 100%;
    min-width: 177.78vh;
    transform: translate(-50%, -50%);
    border: none;
  }

  .overlay-top {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 40%;
    background: linear-gradient(to bottom, var(--bg), transparent);
    z-index: 1;
  }

  .overlay-bottom {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 70%;
    background: linear-gradient(to top, var(--bg) 15%, transparent);
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 3;
    width: 100%;
    padding: 0 56px 36px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
  }

  .hero-info {
    display: flex;
    flex-direction: column;
    gap: 0.5vh;
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUp 0.8s ease 1s forwards;
    width: fit-content;
  }

  .hero-textes {
    display: flex;
    flex-direction: column;
    gap: 0px;
  }

  .hero-nom {
    font-family: Helvetica, Arial, sans-serif;
    font-weight: 800;
    font-size: 96px;
    line-height: 1;
    letter-spacing: 4px;
    color: #ffffff;
    text-shadow: 0 2px 4px rgba(0,0,0,0.9), 0 4px 24px rgba(0,0,0,0.8);
    white-space: nowrap;
    margin-left: -4px;
  }

  .hero-fonction {
    font-family: Helvetica, Arial, sans-serif;
    font-weight: 800;
    font-size: 32px;
    line-height: 1;
    text-transform: uppercase;
    color: #ffffff;
    text-shadow: 0 2px 4px rgba(0,0,0,0.9), 0 4px 24px rgba(0,0,0,0.8);
    white-space: nowrap;
    letter-spacing: 3px;
  }

  .reseaux {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-top: 0.5vh;
    width: 100%;
  }


  .reseau-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
  }

  .reseau-btn.actif {
    color: rgba(255,255,255,0.9);
    cursor: pointer;
  }

  .reseau-btn.actif:hover {
    color: var(--accent);
  }

  .reseau-btn.inactif {
    color: rgba(255,255,255,0.4);
    opacity: 0.35;
    cursor: not-allowed;
  }

  .reseau-icone svg {
    width: 32px;
    height: 32px;
    min-width: 32px;
    min-height: 32px;
    display: block;
    color: inherit;
    fill: none;
    stroke: currentColor;
  }

  .reseau-icone {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    flex-shrink: 0;
  }

  .reseau-img {
    width: clamp(20px, 2.5vw, 36px);
    height: clamp(20px, 2.5vw, 36px);
    object-fit: contain;
    object-position: bottom;
    filter: brightness(0) invert(1);
    transition: filter 0.2s;
    display: block;
  }

/* Taille spécifique pour le logo IMDb (déjà présent) */
  .imdb-img {
    width: clamp(30px, 3.5vw, 52px) !important;
    height: clamp(30px, 3.5vw, 52px) !important;
  }

  /* --- NOUVELLES TAILLES --- */

  /* Taille pour le logo Mail */
/* Taille pour le logo Mail (Légèrement boosté) */
  .mail-img {
    width: clamp(22px, 2.8vw, 39px) !important;
    height: clamp(22px, 2.8vw, 39px) !important;
  }

  /* Taille pour le logo Lightyshare (Juste un peu plus grand) */
  .lighty-img {
    width: clamp(24px, 3vw, 42px) !important;
    height: clamp(24px, 3vw, 42px) !important;
  }
  .reseau-btn.actif:hover .reseau-img {
    filter: brightness(0) saturate(100%) invert(93%) sepia(61%) saturate(600%) hue-rotate(10deg) brightness(103%);
  }



  .inactif-img { opacity: 0.5; }

  .scroll-hint {
    color: rgba(255,255,255,0.5);
    opacity: 0;
    animation: fadeIn 0.8s ease 1.8s forwards;
    transition: color 0.2s;
    padding-bottom: 8px;
  }
  .scroll-hint:hover { color: var(--accent); }

  .onglets {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--bg);
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--border);
    padding: 0 56px;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .onglets::-webkit-scrollbar { display: none; }
  .onglet {
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-muted);
    padding: 20px 24px;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
    transition: color 0.2s, border-color 0.2s;
  }
  .onglet:hover { color: var(--text); }
  .onglet.actif { color: var(--accent); border-bottom-color: var(--accent); }

  .films-liste {
    padding: 64px 56px;
    display: flex;
    flex-direction: column;
  }
  .film-card { padding: 48px 0; }
  .film-separateur {
    height: 1px;
    background: var(--border);
    margin-top: 48px;
  }
  .film-card:last-child .film-separateur { display: none; }

  .film-header {
    margin-bottom: 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .film-titre {
    font-family: Helvetica, Arial, sans-serif;
    font-weight: 800;
    font-size: 38px;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--text);
  }
  .film-titre a:hover { color: var(--accent); }

  .film-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .sep {
    color: var(--text-muted);
    font-size: 20px;
    line-height: 1;
    opacity: 0.8;
  }

  .film-genre-label { color: var(--accent); }

  .film-real {
    font-size: 13px;
    letter-spacing: 1px;
    color: var(--text-muted);
  }

  .real-label { color: var(--accent); }

  .film-roles {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .role-tag {
    font-size: 13px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-muted);
    border: 1px solid var(--border);
    padding: 4px 12px;
    font-weight: 800;
  }

  .film-prix-card {
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--accent);
  }

  .film-visuel {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
    align-items: stretch;
  }
  .film-cover {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
    min-height: 480px;
    overflow: hidden;
    background: var(--bg-surface);
  }
  .film-cover img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
    filter: none;
  }
  .cover-placeholder {
    width: 100%; height: 100%;
    min-height: 480px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }
  .film-cover-overlay {
    position: absolute;
    inset: 0;
    background: rgba(26, 31, 46, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .voir-projet {
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 10px 24px;
  }
  .film-cover:hover img { transform: scale(1.06); }
  .film-cover:hover .film-cover-overlay { opacity: 1; }

  .film-mosaique {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(3, 1fr);
    gap: 4px;
    height: 100%;
  }
  .mosaique-item {
    overflow: hidden;
    background: var(--bg-surface);
    border: none;
    padding: 0;
    cursor: pointer;
    display: block;
    width: 100%;
    height: 100%;
  }
  .mosaique-item img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
    filter: none;
    pointer-events: none;
  }
  .mosaique-item:hover img { transform: scale(1.10); }

  .film-infos-bas {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .film-duree {
    text-transform: none;
  }

  .infos-ligne {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 4px;
  }

  .infos-item {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .infos-row {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .infos-poste {
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--accent);
    opacity: 0.7;
  }

  .infos-nom {
    font-size: 13px;
    letter-spacing: 0.5px;
    color: var(--text-muted);
  }

  .dot {
    color: var(--border);
    font-size: 10px;
  }

  .separateur-bloc {
    color: var(--text-muted);
    font-size: 16px;
    margin: 0 8px;
    opacity: 0.5;
  }

  .cameras-bloc {
    display: flex;
    flex-direction: column;
    gap: 0px;
    line-height: 1.2;
  }

  .camera-emoji { font-size: 16px; }

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .lightbox.open { opacity: 1; pointer-events: all; }
  .lightbox-bg {
    position: absolute;
    inset: 0;
    background: rgba(8, 10, 16, 0.97);
    cursor: pointer;
  }
  .lightbox-img {
    position: relative;
    z-index: 1;
    max-width: 88vw;
    max-height: 88vh;
    object-fit: contain;
    transition: opacity 0.2s ease;
  }
  .lightbox-close {
    position: absolute;
    top: 24px; right: 32px;
    z-index: 2;
    background: none;
    border: 1px solid rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.7);
    font-size: 16px;
    width: 40px; height: 40px;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .lightbox-close:hover { color: var(--accent); border-color: var(--accent); }
  .lightbox-prev, .lightbox-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    background: none;
    border: 1px solid rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.7);
    font-size: 32px;
    width: 48px; height: 48px;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .lightbox-prev { left: 32px; }
  .lightbox-next { right: 32px; }
  .lightbox-prev:hover,
  .lightbox-next:hover { color: var(--accent); border-color: var(--accent); }
  .lightbox-counter {
    position: absolute;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    font-size: 12px;
    letter-spacing: 2px;
    color: rgba(255,255,255,0.4);
  }

  @keyframes fadeUp { to { opacity: 1; transform: translateY(0); } }
  @keyframes fadeIn { to { opacity: 1; } }
</style>

<script is:inline>
  let currentPhotos = [];
  let currentIndex = 0;

  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img');
  const lightboxBg = document.getElementById('lightbox-bg');
  const lightboxClose = document.getElementById('lightbox-close');
  const lightboxPrev = document.getElementById('lightbox-prev');
  const lightboxNext = document.getElementById('lightbox-next');
  const lightboxCounter = document.getElementById('lightbox-counter');

  function openLightbox(photos, index) {
    currentPhotos = photos;
    currentIndex = index;
    showPhoto();
    lightbox.classList.add('open');
  }

  function closeLightbox() {
    lightbox.classList.remove('open');
  }

  function showPhoto() {
    lightboxImg.style.opacity = '0';
    setTimeout(() => {
      lightboxImg.src = currentPhotos[currentIndex];
      lightboxImg.style.opacity = '1';
    }, 150);
    lightboxCounter.textContent = (currentIndex + 1) + ' / ' + currentPhotos.length;
  }

  document.querySelectorAll('.film-mosaique').forEach(function(mosaique) {
    const photos = JSON.parse(mosaique.dataset.photos);
    mosaique.querySelectorAll('.mosaique-item').forEach(function(btn) {
      btn.addEventListener('click', function() {
        openLightbox(photos, parseInt(btn.dataset.index));
      });
    });
  });

  lightboxClose.addEventListener('click', closeLightbox);
  lightboxBg.addEventListener('click', closeLightbox);

  lightboxPrev.addEventListener('click', function() {
    currentIndex = (currentIndex - 1 + currentPhotos.length) % currentPhotos.length;
    showPhoto();
  });

  lightboxNext.addEventListener('click', function() {
    currentIndex = (currentIndex + 1) % currentPhotos.length;
    showPhoto();
  });

  document.addEventListener('keydown', function(e) {
    if (!lightbox.classList.contains('open')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') {
      currentIndex = (currentIndex - 1 + currentPhotos.length) % currentPhotos.length;
      showPhoto();
    }
    if (e.key === 'ArrowRight') {
      currentIndex = (currentIndex + 1) % currentPhotos.length;
      showPhoto();
    }
  });
</script>