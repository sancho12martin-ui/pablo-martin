---
import Layout from '../layouts/Layout.astro';
import films from '../data/narratif.json';
import { getFilmImages } from '../lib/cloudinary.js';

const filmsAvecImages = await Promise.all(
  films.map(async (film: any) => {
    const { cover, images_film } = await getFilmImages(film.slug);
    return {
      ...film,
      cover: cover || null,
      photos: images_film,
    };
  })
);

const reseaux = [
  {
    nom: "Email",
    url: "mailto:pablo12martin@gmail.com",
    actif: true,
    svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 7l10 7 10-7"/></svg>`
  },
  {
    nom: "Instagram",
    url: "https://www.instagram.com/instouzou/",
    actif: true,
    svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/></svg>`
  },
  {
    nom: "Vimeo",
    url: "https://vimeo.com/user128877784",
    actif: true,
    svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 7.42c-.09 2.28-1.7 5.4-4.72 9.36C14.2 20.84 11.56 23 9.37 23c-1.32 0-2.43-1.22-3.35-3.65L4.1 13.23C3.5 10.8 2.85 9.58 2.16 9.58c-.15 0-.68.32-1.6.95L0 9.24c1-.9 1.99-1.79 2.96-2.68C4.28 5.3 5.27 4.6 5.94 4.52c1.56-.15 2.52.91 2.89 3.18.4 2.44.67 3.96.82 4.54.46 2.08.96 3.12 1.51 3.12.43 0 1.07-.67 1.93-2.02.86-1.35 1.32-2.38 1.38-3.1.12-1.17-.34-1.76-1.38-1.76-.49 0-1 .11-1.51.34 1-3.3 2.92-4.9 5.75-4.82 2.1.06 3.08 1.42 2.97 4.08z"/></svg>`
  },
  {
    nom: "YouTube",
    url: "https://www.youtube.com/@Pablo12Martin",
    actif: true,
    svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="currentColor" stroke="none"/></svg>`
  },
  {
    nom: "Lightyshare",
    url: "https://www.lightyshare.com/fr/public/15940/show",
    actif: true,
    img: `/images/Lightyshare_logo.png`
  },
  {
    nom: "IMDb",
    url: null,
    actif: true,
    img: `/images/IMBd_logo.png`
  },
];

const vimeoId = "1191904895";
---

<Layout title="Pablo Martin — Directeur de la Photographie">

  <section class="hero">
    <div class="video-bg">
      <iframe
        src={`https://player.vimeo.com/video/${vimeoId}?autoplay=1&muted=1&loop=1&background=1`}
        frameborder="0"
        allow="autoplay; fullscreen"
        allowfullscreen
      ></iframe>
    </div>
    <div class="overlay-top"></div>
    <div class="overlay-bottom"></div>
    <div class="hero-content">
      <div class="hero-info">
        <div class="hero-textes">
          <h1 class="hero-nom">Pablo Martin</h1>
          <p class="hero-fonction">Directeur de la Photographie</p>
        </div>
        <div class="reseaux">
          {reseaux.map((r) => (
            r.actif ? (
              <a href={r.url} target="_blank" rel="noopener" class="reseau-btn actif" aria-label={r.nom}>
                {'img' in r
                  ? <img src={r.img} alt={r.nom} class="reseau-img" />
                  : <Fragment set:html={r.svg} />
                }
              </a>
            ) : (
              <span class="reseau-btn inactif" title={`${r.nom} — bientôt disponible`}>
                {'img' in r
                  ? <img src={r.img} alt={r.nom} class="reseau-img inactif-img" />
                  : <Fragment set:html={r.svg} />
                }
              </span>
            )
          ))}
        </div>
      </div>
      <a href="#nav-onglets" class="scroll-hint">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M10 4v12M4 10l6 6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </section>

  <nav class="onglets" id="nav-onglets">
    <a href="#narratif" class="onglet actif">Narratif</a>
    <a href="/video" class="onglet">Vidéo</a>
    <a href="/etalonnage" class="onglet">Étalonnage</a>
    <a href="/timeline" class="onglet">Timeline</a>
    <a href="/contact" class="onglet">Contact</a>
  </nav>

  <section class="films-liste" id="narratif">
    {filmsAvecImages.map((film: any) => (
      <article class="film-card">

        <div class="film-header">
          <h2 class="film-titre">
            <a href={`/narratif/${film.slug}`}>{film.titre}</a>
          </h2>
          <div class="film-meta">
            {film.genre && <span>{film.genre}</span>}
            {film.annee && <><span class="sep">·</span><span>{film.annee}</span></>}
            {film.pays && <><span class="sep">·</span><span>{film.pays}</span></>}
            {film.duree && <><span class="sep">·</span><span>{film.duree.replace(' min', "'")}</span></>}
          </div>
          <p class="film-real">Réal. {film.real}</p>
          <div class="film-roles">
            {film.roles.map((role: string) => (
              <span class="role-tag">{role}</span>
            ))}
          </div>
        </div>

        <div class="film-visuel">
          <a href={`/narratif/${film.slug}`} class="film-cover">
            {film.cover ? (
              <img src={film.cover} alt={film.titre} loading="lazy" />
            ) : (
              <div class="cover-placeholder">
                <span>Image bientôt disponible</span>
              </div>
            )}
            <div class="film-cover-overlay">
              <span class="voir-projet">Voir le projet →</span>
            </div>
          </a>

          <div class="film-mosaique" data-photos={JSON.stringify(film.photos)}>
            {film.photos.slice(0, 12).map((photo: string, i: number) => (
              <button
                class="mosaique-item"
                data-index={String(i)}
                aria-label={`Agrandir photo ${i + 1}`}
              >
                <img src={photo} alt={`${film.titre} — ${i + 1}`} loading="lazy" />
              </button>
            ))}
          </div>
        </div>

       

        <div class="film-infos-bas">
           {film.prix && (
          <div class="film-prix-card">🏆 {film.prix}</div>
        )}
          {film.credits && (
            <p class="infos-ligne">
              {Object.entries(film.credits)
                .filter(([key, val]: [string, any]) =>
                  val !== null && (
                    key === '1er assistant caméra' ||
                    key === 'Production' ||
                    key === 'Assistant Caméra'
                  )
                )
                .map(([poste, nom]: [string, any], i: number) => (
                  <span class="infos-item">
                    {i > 0 && <span class="dot">·</span>}
                    <span class="infos-poste">{poste}</span>
                    <span class="infos-nom">{nom}</span>
                  </span>
                ))
              }
            </p>
          )}
          {film.credits?.['Prestataires techniques'] && (
            <div class="infos-row">
              <span class="infos-poste">Prestataires</span>
              <span class="infos-nom">{film.credits['Prestataires techniques']}</span>
            </div>
          )}
          {film.cameras && film.cameras.map((cam: any) => (
            <div class="infos-row camera-row">
              <span class="camera-emoji">{cam.type === 'numerique' ? '📹' : '🎥'}</span>
              <span class="infos-nom">{cam.nom}</span>
              {cam.format && <><span class="dot">/</span><span class="infos-nom">{cam.format}</span></>}
              {cam.laboratoire && <><span class="dot">/</span><span class="infos-nom">Labo. {cam.laboratoire}</span></>}
              {cam.type === 'numerique' && cam.optiques && <><span class="dot">/</span><span class="infos-nom">{cam.optiques}</span></>}
            </div>
          ))}
        </div>

        <div class="film-separateur"></div>
      </article>
    ))}
  </section>

  <div class="lightbox" id="lightbox">
    <div class="lightbox-bg" id="lightbox-bg"></div>
    <button class="lightbox-close" id="lightbox-close">✕</button>
    <button class="lightbox-prev" id="lightbox-prev">‹</button>
    <button class="lightbox-next" id="lightbox-next">›</button>
    <img class="lightbox-img" id="lightbox-img" src="" alt="" />
    <p class="lightbox-counter" id="lightbox-counter"></p>
  </div>

</Layout>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 65vh;
    min-height: 400px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }
  .video-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .video-bg iframe {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 177.78vh;
    height: 100vh;
    min-width: 100%;
    min-height: 100%;
    transform: translate(-50%, -50%);
    border: none;
  }
  .overlay-top {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 40%;
    background: linear-gradient(to bottom, var(--bg), transparent);
    z-index: 1;
  }
  .overlay-bottom {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 70%;
    background: linear-gradient(to top, var(--bg) 15%, transparent);
    z-index: 1;
  }
  .hero-content {
    position: relative;
    z-index: 3;
    width: 100%;
    padding: 0 56px 36px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
  }
  .hero-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUp 0.8s ease 1s forwards;
  }
  .hero-textes {
    display: inline-flex;
    flex-direction: column;
    gap: 4px;
  }
  .hero-nom {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-weight: 800;
    font-size: clamp(2.8rem, 6.5vw, 6rem);
    line-height: 1;
    letter-spacing: 0.05em;
    color: #ffffff;
    text-shadow: 0 0 0 2px rgba(0,0,0,0.9), 2px 2px 0 rgba(0,0,0,0.8), 0 4px 20px rgba(0,0,0,1), 0 0 60px rgba(0,0,0,0.9);
    -webkit-text-stroke: 1px rgba(0,0,0,0.5);
  }
  .hero-fonction {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-weight: 800;
    font-size: clamp(1.2rem, 2.5vw, 2.2rem);
    line-height: 1;
    text-transform: uppercase;
    color: #ffffff;
    text-shadow: 0 0 0 2px rgba(0,0,0,0.9), 2px 2px 0 rgba(0,0,0,0.8), 0 4px 20px rgba(0,0,0,1), 0 0 60px rgba(0,0,0,0.9);
    -webkit-text-stroke: 1px rgba(0,0,0,0.5);
    text-align: justify;
    text-align-last: justify;
  }
  .reseaux {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 4px;
  }
  .reseau-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px; height: 38px;
    transition: color 0.2s;
  }
  .reseau-btn svg { width: 17px; height: 17px; }
  .reseau-btn.actif { color: rgba(255,255,255,0.9); cursor: pointer; }
  .reseau-btn.actif:hover { color: var(--accent); }
  .reseau-btn.inactif { color: rgba(255,255,255,0.4); opacity: 0.35; cursor: not-allowed; }
  .scroll-hint {
    color: rgba(255,255,255,0.5);
    opacity: 0;
    animation: fadeIn 0.8s ease 1.8s forwards;
    transition: color 0.2s;
    padding-bottom: 8px;
  }
  .scroll-hint:hover { color: var(--accent); }

  .onglets {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--bg);
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--border);
    padding: 0 56px;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .onglets::-webkit-scrollbar { display: none; }
  .onglet {
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
    padding: 20px 24px;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
    transition: color 0.2s, border-color 0.2s;
  }
  .onglet:hover { color: var(--text); }
  .onglet.actif { color: var(--accent); border-bottom-color: var(--accent); }

  .films-liste {
    padding: 64px 56px;
    display: flex;
    flex-direction: column;
  }
  .film-card { padding: 48px 0; }
  .film-separateur {
    height: 1px;
    background: var(--border);
    margin-top: 48px;
  }
  .film-card:last-child .film-separateur { display: none; }

  .film-header {
    margin-bottom: 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .film-titre {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-weight: 800;
    font-size: clamp(1.6rem, 2.8vw, 2.4rem);
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--text);
  }
  .film-titre a:hover { color: var(--accent); }
  .film-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .sep {
    color: var(--text-muted);
    font-size: 1.5rem;
    line-height: 1;
    opacity: 0.8;
  }
  .film-real {
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    color: var(--text-muted);
  }
  .film-roles {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .role-tag {
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    border: 1px solid var(--border);
    padding: 4px 12px;
  }

  .film-visuel {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
    align-items: stretch;
  }
  .film-cover {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
    min-height: 480px;
    overflow: hidden;
    background: var(--bg-surface);
  }
  .film-cover img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
    filter: none;
  }
  .cover-placeholder {
    width: 100%; height: 100%;
    min-height: 480px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .film-cover-overlay {
    position: absolute;
    inset: 0;
    background: rgba(26, 31, 46, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .voir-projet {
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 10px 24px;
  }
  .film-cover:hover img { transform: scale(1.06); }
  .film-cover:hover .film-cover-overlay { opacity: 1; }

  .film-mosaique {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(3, 1fr);
    gap: 4px;
    height: 100%;
  }
  .mosaique-item {
    overflow: hidden;
    background: var(--bg-surface);
    border: none;
    padding: 0;
    cursor: pointer;
    display: block;
    width: 100%;
    height: 100%;
  }
  .mosaique-item img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
    filter: none;
    pointer-events: none;
  }
  .mosaique-item:hover img { transform: scale(1.10); }

  .film-prix-card {
    font-size: 1rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-top: 12px;
  }

  .film-infos-bas {
    margin-top: 6px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .infos-row {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .infos-poste {
    font-size: 1rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    opacity: 0.7;
  }
  .infos-nom {
    font-size: 0.82rem;
    letter-spacing: 0.05em;
    color: var(--text-muted);
  }
  .dot {
    color: var(--border);
    font-size: 0.65rem;
  }
  .camera-emoji { font-size: 1.3rem; }

  .reseau-img {
    width: 35px;
    height: 35px;
    object-fit: contain;
    filter: brightness(0) invert(1);
    transition: filter 0.2s;
  }
  .reseau-btn.actif:hover .reseau-img {
    filter: brightness(0) saturate(100%) invert(93%) sepia(61%) saturate(600%) hue-rotate(10deg) brightness(103%);
  }
  .inactif-img { opacity: 0.5; }

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .lightbox.open { opacity: 1; pointer-events: all; }
  .lightbox-bg {
    position: absolute;
    inset: 0;
    background: rgba(8, 10, 16, 0.97);
    cursor: pointer;
  }
  .lightbox-img {
    position: relative;
    z-index: 1;
    max-width: 88vw;
    max-height: 88vh;
    object-fit: contain;
    transition: opacity 0.2s ease;
  }
  .lightbox-close {
    position: absolute;
    top: 24px; right: 32px;
    z-index: 2;
    background: none;
    border: 1px solid rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.7);
    font-size: 1rem;
    width: 40px; height: 40px;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .lightbox-close:hover { color: var(--accent); border-color: var(--accent); }
  .lightbox-prev, .lightbox-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    background: none;
    border: 1px solid rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.7);
    font-size: 2rem;
    width: 48px; height: 48px;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .lightbox-prev { left: 32px; }
  .lightbox-next { right: 32px; }
  .lightbox-prev:hover,
  .lightbox-next:hover { color: var(--accent); border-color: var(--accent); }
  .lightbox-counter {
    position: absolute;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    color: rgba(255,255,255,0.4);
  }

  @keyframes fadeUp { to { opacity: 1; transform: translateY(0); } }
  @keyframes fadeIn { to { opacity: 1; } }
</style>

<script is:inline>
  let currentPhotos = [];
  let currentIndex = 0;

  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img');
  const lightboxBg = document.getElementById('lightbox-bg');
  const lightboxClose = document.getElementById('lightbox-close');
  const lightboxPrev = document.getElementById('lightbox-prev');
  const lightboxNext = document.getElementById('lightbox-next');
  const lightboxCounter = document.getElementById('lightbox-counter');

  function openLightbox(photos, index) {
    currentPhotos = photos;
    currentIndex = index;
    showPhoto();
    lightbox.classList.add('open');
  }

  function closeLightbox() {
    lightbox.classList.remove('open');
  }

  function showPhoto() {
    lightboxImg.style.opacity = '0';
    setTimeout(() => {
      lightboxImg.src = currentPhotos[currentIndex];
      lightboxImg.style.opacity = '1';
    }, 150);
    lightboxCounter.textContent = (currentIndex + 1) + ' / ' + currentPhotos.length;
  }

  document.querySelectorAll('.film-mosaique').forEach(function(mosaique) {
    const photos = JSON.parse(mosaique.dataset.photos);
    mosaique.querySelectorAll('.mosaique-item').forEach(function(btn) {
      btn.addEventListener('click', function() {
        openLightbox(photos, parseInt(btn.dataset.index));
      });
    });
  });

  lightboxClose.addEventListener('click', closeLightbox);
  lightboxBg.addEventListener('click', closeLightbox);

  lightboxPrev.addEventListener('click', function() {
    currentIndex = (currentIndex - 1 + currentPhotos.length) % currentPhotos.length;
    showPhoto();
  });

  lightboxNext.addEventListener('click', function() {
    currentIndex = (currentIndex + 1) % currentPhotos.length;
    showPhoto();
  });

  document.addEventListener('keydown', function(e) {
    if (!lightbox.classList.contains('open')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') {
      currentIndex = (currentIndex - 1 + currentPhotos.length) % currentPhotos.length;
      showPhoto();
    }
    if (e.key === 'ArrowRight') {
      currentIndex = (currentIndex + 1) % currentPhotos.length;
      showPhoto();
    }
  });
</script>